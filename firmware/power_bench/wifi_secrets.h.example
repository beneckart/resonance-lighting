#pragma once

// Copy to wifi_secrets.h (gitignored) and fill in. Needed for station-mode WiFi
// so a battery-powered board joins the LAN and serves /telemetry untethered.

#define RES_WIFI_SSID "your-network"
#define RES_WIFI_PASSWORD "your-password"

// Set to 1 for unattended bench runs so every boot joins WiFi and starts the
// web server (OTA + /telemetry) automatically.
#define RES_WIFI_AUTO_CONNECT 1
